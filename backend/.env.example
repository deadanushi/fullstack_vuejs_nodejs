NODE_ENV=development
PORT=3000

# MongoDB connection string
# Local: mongodb://localhost:27017/mystore
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/mystore
MONGO_URI=mongodb://localhost:27017/mystore

# JWT — use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d
